# Строка подключения к Postgres (async, драйвер asyncpg)
DATABASE_URL=postgresql+asyncpg://aggregat:aggregat@localhost:5432/aggregat

# Уровень логирования uvicorn/приложения
LOG_LEVEL=info

# Разрешить echo SQL-запросов SQLAlchemy (для отладки, не для прода)
SQL_ECHO=false

# CORS: origin(ы) веб-дашборда, если он на другом хосте/порту, чем API.
# CSV (напр. http://100.93.215.38:8081,https://agg.dustar.pro) или * (self-host).
CORS_ALLOW_ORIGINS=*

# ── Классификация (Фаза 2b) ────────────────────────────────────────────────
# Провайдер LLM: none | anthropic | ollama
#   none     — только правила (без LLM);
#   anthropic— облачный API (нужен ANTHROPIC_API_KEY);
#   ollama   — локальный Ollama ИЛИ Ollama Cloud (см. ниже).
#
# ТЕКУЩАЯ КОНФИГУРАЦИЯ: Ollama Cloud, модель glm-5.2:cloud.
LLM_PROVIDER=ollama
ANTHROPIC_API_KEY=

# Ollama Cloud: адрес + твой API-ключ с ollama.com (Settings → API keys).
# Для локального Ollama вместо этого: OLLAMA_BASE_URL=http://localhost:11434 и пустой ключ.
OLLAMA_BASE_URL=https://ollama.com
OLLAMA_API_KEY=

# Роутер моделей (anthropic): рутина → routine, длинное/неоднозначное → hard.
LLM_MODEL_ROUTINE=claude-haiku-4-5-20251001
LLM_MODEL_HARD=claude-opus-4-8
# Роутер моделей (ollama). Одна GLM-модель на оба тира — роутинг схлопывается,
# но при желании можно поставить более лёгкую cloud-модель на routine.
OLLAMA_MODEL_ROUTINE=glm-5.2:cloud
OLLAMA_MODEL_HARD=glm-5.2:cloud

# Порог эскалации на hard-модель по длине текста (символов).
LLM_ESCALATION_CHAR_THRESHOLD=280
LLM_MAX_TOKENS=512
LLM_TIMEOUT_SECONDS=30
LLM_DEFAULT_CONFIDENCE=0.6

# ── Эмбеддинги / RAG / процессы ─────────────────────────────────────────────
# Ollama Cloud НЕ хостит emb-модели → bge-m3 крутится локально/на хосте.
# Перед запуском: ollama pull bge-m3
# embed_provider=none полностью выключает RAG и процессы.
EMBED_PROVIDER=ollama
EMBED_BASE_URL=http://host.docker.internal:11434
EMBED_API_KEY=
EMBED_MODEL=bge-m3
EMBED_DIM=1024

# Привязка к процессам (RAG)
PROCESS_LINK_TOP_K=5
PROCESS_LINK_SIM_THRESHOLD=0.55
PROCESS_RECENCY_DAYS=30
PROCESS_FREEZE_IDLE_DAYS=7
